{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "core:window:allow-outer-size",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "updater:default",
    "process:default"
  ]
}
